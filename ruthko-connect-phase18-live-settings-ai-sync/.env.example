NODE_ENV=production
PORT=3000
APP_DOMAIN=https://ruthkojobs.com

RESEND_API_KEY=replace_with_resend_api_key
RUTHKO_NOTIFY_TO=info@ruthkojobs.com
RUTHKO_NOTIFY_FROM=Ruthko Connect <no-reply@ruthkojobs.com>
RUTHKO_AUTOREPLY_FROM=Ruthko Connect <no-reply@ruthkojobs.com>
RUTHKO_CAMPAIGN_FROM=Ruthko Connect <no-reply@ruthkojobs.com>
RUTHKO_REPLY_TO=info@ruthkojobs.com
RUTHKO_UNSUBSCRIBE_BASE_URL=https://ruthkojobs.com/.netlify/functions/unsubscribe

SUPABASE_URL=replace_with_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key

STRIPE_SECRET_KEY=replace_later_if_using_vps_checkout
STRIPE_WEBHOOK_SECRET=replace_later_if_using_vps_webhooks

# Optional but recommended. If set, Content Manager saves require this token.
ADMIN_SETTINGS_TOKEN=make_a_long_private_admin_token
